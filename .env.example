# =============================================================================
# DataPilot — Environment Configuration
# =============================================================================
# Copy this file to `.env` in the PROJECT ROOT (same folder as backend/ and
# frontend/) and fill in your own values. NEVER commit your real `.env`.
#
# Minimum to run locally: OPENAI_API_KEY + a warehouse (BigQuery OR Postgres).
# Supabase keys are required for login + chat history.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (OpenAI) — required for the agents
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# Supabase — required for auth + conversation history
# Get these from: Supabase Dashboard -> Project Settings -> API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key is SECRET. Backend chat persistence uses ONLY this key.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Used by LangGraph's AsyncPostgresSaver checkpointer (optional; falls back to in-memory).
# SUPABASE_POSTGRES_URL=postgresql://postgres.<ref>:<password>@<host>:6543/postgres?pgbouncer=true

# Fernet key used to encrypt saved data-source credentials (user_data_sources).
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATAPILOT_CREDENTIALS_KEY=your-generated-fernet-key

# -----------------------------------------------------------------------------
# Warehouse — Option A: BigQuery (default)
# -----------------------------------------------------------------------------
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=retail_data
# Local dev: path to a service-account JSON file (kept out of git).
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
# Serverless (e.g. Vercel): provide the service account inline instead of a file.
# GCP_SERVICE_ACCOUNT_JSON=<minified single-line JSON>
# GCP_SERVICE_ACCOUNT_JSON_B64=<base64 of the entire service-account .json>

# -----------------------------------------------------------------------------
# Warehouse — Option B: PostgreSQL
# Set DATABASE_TYPE=postgres to use this instead of BigQuery.
# -----------------------------------------------------------------------------
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# POSTGRES_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Observability — Langfuse (optional)
# Get keys from: https://cloud.langfuse.com -> Project Settings
# -----------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=sk-lf-your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-langfuse-public-key
LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Frontend <-> API wiring
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000
# CORS: leave unset for local dev (loopback on any port is allowed by default).
# In production, set an explicit allowlist and disable the loopback regex.
# CORS_ALLOW_ORIGINS=https://your-frontend-domain.com
# CORS_ALLOW_ORIGIN_REGEX=

# -----------------------------------------------------------------------------
# Behavior toggles (optional)
# -----------------------------------------------------------------------------
# Skip both human-in-the-loop approval interrupts (handy for a one-shot demo).
# DATAPILOT_SKIP_INTERRUPTS=false
# Suggested-question feature toggles (useful for limiting LLM quota usage).
# SUGGESTED_QUESTIONS_ENABLED=1
# SUGGESTED_QUESTIONS_LLM=1
# SUGGESTED_QUESTIONS_INCLUDE_KB=1
# SUGGESTED_QUESTIONS_CACHE_TTL_SEC=600
# Query Knowledge Base similarity thresholds (optional pgvector retrieval).
# QUERY_KB_MIN_SIMILARITY=0.78
# QUERY_KB_RELAXED_MIN_SIMILARITY=0.68
# LOG_LEVEL=INFO
